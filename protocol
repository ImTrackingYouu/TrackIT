          <img
            key={i}
            src={logoUrl}
            alt=""
            style={{
              position: "absolute",
              left: `${l.x}%`,
              top: `${l.y}%`,
              width: `${l.size}px`,
              height: `${l.size}px`,
              objectFit: "contain",
              ["--logo-op" as string]: l.op,
              animation: `logo-drift ${l.dur}s ease-in-out ${l.delay}s infinite`,
            }}
          />
        ))}
      </div>

      {/* Stars */}
      <div className="pointer-events-none fixed inset-0 z-0 overflow-hidden">
        {STARS.map((s) =>
          s.isCross ? (
            <div
              key={s.id}
              className="absolute text-white select-none"
              style={{
                left: `${s.x}%`,
                top: `${s.y}%`,
                fontSize: `${s.size * 5}px`,
                opacity: s.opacity,
                animation: `twinkle ${s.twinkleDur}s ease-in-out ${s.delay}s infinite, float-star ${s.floatDur}s ease-in-out ${s.delay}s infinite`,
