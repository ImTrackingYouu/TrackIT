const STARS = Array.from({ length: 100 }, (_, i) => {
  const x = ((i * 13.7 + 7) * 97.3) % 100;
  const y = ((i * 31.1 + 3) * 61.7) % 100;
  const size = i % 7 === 0 ? 3.5 : i % 3 === 0 ? 2.5 : 1.5;
  const opacity = 0.45 + (i % 5) * 0.1;
  const twinkleDur = 1.8 + (i % 5) * 0.6;
  const floatDur = 4 + (i % 7) * 0.9;
  const delay = (i * 0.37) % 5;
  const isCross = i % 14 === 0;
  const glow = i % 5 === 0;
  return { id: i, x, y, size, opacity, twinkleDur, floatDur, delay, isCross, glow };
});

function truncateAddress(addr: string) {
  if (addr.length <= 16) return addr;
  return `${addr.slice(0, 8)}...${addr.slice(-6)}`;
}

function formatNumber(n: number) {
  if (n >= 1_000_000) return `${(n / 1_000_000).toFixed(1)}M`;
  if (n >= 1_000) return `${(n / 1_000).toFixed(1)}K`;
  return n.toLocaleString();
}

