            >
              <svg viewBox="0 0 24 24" className="w-4 h-4 fill-current" aria-hidden="true">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.259 5.631 5.905-5.631zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
              </svg>
              <span>@Trackitai</span>
            </a>
          </nav>
        </div>
      </header>

      {/* Hero */}
      <section className="relative z-10 pt-36 pb-24 px-6">
        <div className="relative z-10 max-w-5xl mx-auto">
          <p className="mb-5 text-xs font-mono text-purple-400/60 tracking-widest">// gm · mainnet · live data</p>
          <h1 className="font-display text-5xl md:text-7xl font-bold tracking-tight mb-6 leading-[1.05] text-white drop-shadow-lg max-w-3xl">
            Is your wallet even{" "}
            <span className="bg-gradient-to-r from-purple-400 to-cyan-400 bg-clip-text text-transparent">
              worth tracking?
            </span>
          </h1>
          <p className="text-white/50 text-base mb-10 max-w-md leading-relaxed">
            Paste any Solana wallet. See if it's a real trader, a bot, or an exchange —
            plus their trader tag and how many wallets are already following their moves.
          </p>

          <div className="flex flex-col sm:flex-row gap-3 max-w-xl">
            <div className="flex-1 relative">
              <Search className="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-white/40 pointer-events-none" />
              <input
                id="hero-input"
                data-testid="input-wallet-address"
                type="text"
                value={address}
                onChange={(e) => {
                  setAddress(e.target.value);
                  setError("");
                }}
                onKeyDown={handleKeyDown}
                placeholder="Paste Solana wallet address…"
                className="w-full pl-10 pr-4 py-3 bg-white/5 border border-white/15 rounded-lg text-sm font-mono text-white placeholder:text-white/30 focus:outline-none focus:ring-2 focus:ring-purple-500/50 focus:border-purple-500/50 transition-all backdrop-blur-sm"
              />
            </div>
            <button
              data-testid="button-analyze"
              onClick={handleAnalyze}
              disabled={analyzeWallet.isPending}
              className="px-6 py-3 bg-purple-600 hover:bg-purple-500 text-white rounded-lg text-sm font-semibold transition-colors disabled:opacity-60 flex items-center gap-2 justify-center min-w-[110px] shadow-lg shadow-purple-900/40"
            >
              {analyzeWallet.isPending ? (
                <>
                  <span className="w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin" />
                  Analyzing…
                </>
              ) : (
                <>
                  Analyze
                  <ArrowRight className="w-4 h-4" />
                </>
              )}
            </button>
          </div>

          {error && (
            <p data-testid="text-error" className="mt-3 text-sm text-red-400">
              {error}
            </p>
          )}

          {recentSearches && recentSearches.length > 0 && (
            <div className="mt-5 flex flex-wrap gap-2 items-center">
              <span className="text-xs font-mono text-white/30">recently cooked:</span>
              {recentSearches.slice(0, 3).map((s) => (
                <button
                  key={s.address}
                  data-testid={`button-recent-${s.address}`}
                  onClick={() => setLocation(`/dashboard/${s.address}`)}
                  className="text-xs font-mono text-white/35 hover:text-purple-400 transition-colors border border-white/10 rounded px-2 py-0.5 hover:border-purple-500/40"
                >
                  {truncateAddress(s.address)}
                </button>
              ))}
            </div>
          )}
        </div>
      </section>

      {/* Stats */}
      <section id="analytics" className="relative z-10 px-6 pb-20">
        <div className="max-w-5xl mx-auto border border-white/10 rounded-xl overflow-hidden divide-y md:divide-y-0 md:divide-x divide-white/10 grid grid-cols-2 md:grid-cols-4">
          {[
            {
              label: "Wallets Checked",
              value: statsLoading ? null : formatNumber(stats?.walletsAnalyzed ?? 0),
            },
            {
              label: "Daily Lookups",
              value: statsLoading ? null : formatNumber(stats?.dailySearches ?? 0),
            },
            {
              label: "Txs Analyzed",
              value: statsLoading ? null : formatNumber(stats?.trackingSignals ?? 0),
            },
            {
              label: "Avg Degen Score",
              value: statsLoading ? null : `${stats?.avgActivityScore?.toFixed(1) ?? "0"}`,
            },
          ].map((stat) => (
            <div key={stat.label} className="px-6 py-5 bg-white/[0.02]">
              {stat.value === null ? (
                <Skeleton className="h-7 w-16 mb-2 bg-white/10" />
              ) : (
                <p
                  data-testid={`text-stat-${stat.label.toLowerCase().replace(/ /g, "-")}`}
                  className="text-2xl font-bold font-mono text-purple-400 mb-1"
                >
                  {stat.value}
                </p>
              )}
              <p className="text-xs text-white/40 font-mono">{stat.label}</p>
            </div>
          ))}
        </div>
      </section>

      {/* Features */}
      <section id="features" className="relative z-10 px-6 pb-28">
        <div className="max-w-5xl mx-auto">
          <div className="flex justify-center mb-10">
            <div className="flex items-center gap-3 border border-purple-500/30 bg-purple-500/5 rounded-lg px-4 py-2.5 backdrop-blur-sm">
              <span className="text-xs font-mono font-bold text-purple-400 shrink-0">CA:</span>
              {CA_ADDRESS ? (
                <>
                  <span className="text-xs font-mono text-white/70 break-all">{CA_ADDRESS}</span>
                  <button
                    onClick={() => navigator.clipboard.writeText(CA_ADDRESS)}
                    className="shrink-0 text-white/30 hover:text-purple-400 transition-colors"
                    title="Copy CA"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" className="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
                      <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
                    </svg>
                  </button>
                </>
              ) : (
                <span className="text-xs font-mono text-white/25 italic">coming soon</span>
              )}
            </div>
          </div>
          <h2 className="font-display text-center text-2xl font-bold mb-3 text-white">
            Do you have motion?
          </h2>
          <p className="text-center text-white/50 text-sm mb-12 max-w-md mx-auto">
            Let's see how many other people trust your judgment.
          </p>
          <div className="grid md:grid-cols-3 gap-px bg-white/10 border border-white/10 rounded-xl overflow-hidden">
            {[
              {
                num: "01",
                title: "Copytrader count",
                desc: "Estimated wallets already copying this trader — calculated from win rate, activity, and volume on mainnet. Recalculates every lookup.",
                accent: "border-purple-500",
              },
              {
                num: "02",
                title: "Bot, exchange, or actual degen?",
                desc: "Detected from on-chain patterns. Near-perfect win rate at huge volume = sniper bot. Massive SOL with 100+ tokens = exchange. Everything else = a real human you might want to copy.",
                accent: "border-cyan-500",
              },
              {
                num: "03",
                title: "Their tag — Chad, Degen, or cooked",
                desc: "Every wallet gets tagged from real on-chain signals. Degen if they're sending it. Ghost if they've gone quiet. No cope, no made-up scores.",
                accent: "border-purple-500",
              },
            ].map((f) => (
              <div
                key={f.title}
                className={`bg-[#0a0015] p-6 hover:bg-white/[0.03] transition-colors border-t-2 ${f.accent}`}
              >
                <span className="block font-mono text-3xl font-bold text-white/8 mb-4 select-none">
                  {f.num}.
                </span>
                <h3 className="font-semibold mb-2 text-sm text-white">
                  {f.title}
                </h3>
                <p className="text-white/45 text-xs leading-relaxed">
                  {f.desc}
                </p>
              </div>
            ))}
          </div>
        </div>
      </section>

      {/* Footer */}
      <footer className="relative z-10 border-t border-white/8 px-6 py-10 bg-black/20 backdrop-blur-sm">
        <div className="max-w-5xl mx-auto">
          <div className="flex flex-col md:flex-row items-start justify-between gap-8 mb-8">
            <div>
              <div className="flex items-center gap-2 mb-3">
                <img
                  src={logoUrl}
                  alt="TrackIT logo"
                  className="w-7 h-7 object-contain"
                />
                <span className="font-bold text-white">TrackIT</span>
              </div>
              <p className="text-xs text-white/40 max-w-xs leading-relaxed">
                Reads straight from Solana mainnet. Not financial advice.
              </p>
            </div>
            <div className="flex gap-12 text-xs text-white/50">
              <div className="flex flex-col gap-2">
                <span className="text-white font-medium mb-1">Product</span>
                <a
                  href="#features"
                  className="hover:text-white transition-colors"
                >
                  Features
                </a>
                <a
                  href="#analytics"
                  className="hover:text-white transition-colors"
                >
                  Analytics
                </a>
                <button
                  onClick={() => setLocation("/leaderboard")}
                  className="text-left hover:text-white transition-colors"
