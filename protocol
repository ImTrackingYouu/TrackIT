            </div>
          ) : (
            <div
              key={s.id}
              className="absolute rounded-full bg-white"
              style={{
                left: `${s.x}%`,
                top: `${s.y}%`,
                width: `${s.size}px`,
                height: `${s.size}px`,
                opacity: s.opacity,
                animation: `twinkle ${s.twinkleDur}s ease-in-out ${s.delay}s infinite, float-star ${s.floatDur}s ease-in-out ${s.delay}s infinite`,
                ["--star-op" as string]: s.opacity,
                boxShadow: s.glow ? `0 0 ${s.size * 3}px ${s.size}px rgba(180,140,255,0.6)` : undefined,
